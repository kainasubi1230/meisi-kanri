generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model BusinessCard {
  id            String   @id @default(cuid())
  userId        String   @db.VarChar(128)
  fullName      String?  @db.VarChar(191)
  company       String?  @db.VarChar(191)
  department    String?  @db.VarChar(191)
  title         String?  @db.VarChar(191)
  email         String?  @db.VarChar(191)
  phone         String?  @db.VarChar(64)
  address       String?  @db.VarChar(512)
  website       String?  @db.VarChar(191)
  memo          String?  @db.Text
  imageBase64   String?  @db.Text
  imageMimeType String?  @db.VarChar(64)
  confidence    Json?
  rawExtraction Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  shares        BusinessCardShare[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, fullName])
  @@index([userId, company])
  @@index([userId, email])
}

model AppUser {
  id           String   @id @default(cuid())
  email        String   @unique @db.VarChar(191)
  passwordHash String   @db.VarChar(255)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model BusinessCardShare {
  id               String       @id @default(cuid())
  cardId           String
  ownerUserId      String       @db.VarChar(128)
  sharedWithUserId String       @db.VarChar(191)
  createdAt        DateTime     @default(now())
  card             BusinessCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([cardId, sharedWithUserId])
  @@index([sharedWithUserId, createdAt(sort: Desc)])
  @@index([ownerUserId])
}

model AppUserShare {
  id               String   @id @default(cuid())
  ownerUserId      String   @db.VarChar(191)
  sharedWithUserId String   @db.VarChar(191)
  createdAt        DateTime @default(now())

  @@unique([ownerUserId, sharedWithUserId])
  @@index([sharedWithUserId, createdAt(sort: Desc)])
}
